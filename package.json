{
  "name": "telegram",
  "version": "0.1.0",
  "private": false,
  "description": "Personal Telegram CLI built with incur and mtcute",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "telegram": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx/esm src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mtcute/node": "^0.29.6",
    "dotenv": "^17.4.2",
    "incur": "^0.3.25",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
